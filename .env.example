# Provider options: openrouter or openai
AI_PROVIDER=openrouter

# OpenRouter settings
OPENROUTER_API_KEY=your_openrouter_api_key_here
AI_MODEL=openai/gpt-4o-mini

# Local server settings
PORT=3000
HOST=127.0.0.1

